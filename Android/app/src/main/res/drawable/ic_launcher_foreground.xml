<?xml version="1.0" encoding="utf-8"?>
<!--
  A serif "C" centered on the 108dp launcher canvas. The viewport is
  108x108 with the safe inset that adaptive icons require (the visible
  area is the inner 66x66; outer area can be cropped by the system).

  The glyph is hand-drawn as a filled path so it reads at any size, on
  the indigo accent. Background is the paper color from the adaptive
  icon's background layer.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- A serif capital C: drawn as a thick crescent with two small
         serif terminals at the top and bottom of the opening. The fill
         color matches the indigo accent (#5B5E8C). -->
    <path
        android:fillColor="#5B5E8C"
        android:pathData="
            M 70,42
            C 64,36 56,33 49,33
            C 38,33 30,42 30,54
            C 30,66 38,75 49,75
            C 56,75 64,72 70,66
            L 67,62
            C 62,67 56,69 50,69
            C 41,69 36,62 36,54
            C 36,46 41,39 50,39
            C 56,39 62,41 67,46
            Z" />

    <!-- Small serif terminals: a horizontal stub at the top-right of
         the C's opening, and another at the bottom-right. These give
         the glyph the slightly old-fashioned look the rest of the app
         is reaching for. -->
    <path
        android:fillColor="#5B5E8C"
        android:pathData="
            M 67,40
            L 75,40
            L 75,44
            L 67,44 Z
            M 67,64
            L 75,64
            L 75,68
            L 67,68 Z" />
</vector>
