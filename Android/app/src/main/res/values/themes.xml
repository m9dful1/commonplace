<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Compose owns the look; this is just the splash/window backdrop so the
         system status bar and pre-Compose frame are paper-colored, not white. -->
    <style name="Theme.Commonplace" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">@color/paper</item>
        <item name="android:statusBarColor">@color/paper</item>
        <item name="android:navigationBarColor">@color/paper</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
    </style>
</resources>
